<pre v-if="language" class="grid text-sm max-h-[650px] overflow-y-auto rounded-xl scrollbar"><code v-text="code" :class="'language-' + language + ' !bg-muted/40 !p-3.5'"></code></pre>
<pre v-else class="grid text-sm max-h-[650px] overflow-y-auto rounded-xl scrollbar"><code v-text="code" class="!bg-muted/40 !p-3.5"></code></pre>
