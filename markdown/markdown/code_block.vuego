<pre v-if="language" class="grid text-sm max-h-[650px] overflow-y-auto rounded-xl scrollbar"><code :class="'language-' + language + ' !bg-muted/40 !p-3.5'">{{ code }}</code></pre>
<pre v-else class="grid text-sm max-h-[650px] overflow-y-auto rounded-xl scrollbar"><code class="!bg-muted/40 !p-3.5">{{ code }}</code></pre>
